# ---------------------------------------------------------------------------
# Sentio Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------------------------

# Claude AI guidance (optional)
# Get your key at https://console.anthropic.com
# If left empty, the system falls back to static emotion guidance strings.
ANTHROPIC_API_KEY=sk-ant-...

# Model used for guidance generation (default: claude-haiku-4-5)
# Haiku is recommended — fast, low-latency, cost-efficient for real-time use.
# GUIDANCE_MODEL=claude-haiku-4-5

# Seconds before the same emotion state triggers a new Claude call (default: 20)
# GUIDANCE_CACHE_TTL=20.0
