# Vercel multi-service deployment.
# The backend is routed to /_/backend by vercel.json experimentalServices.
# runtimeConfig.ts resolves this path against window.location.origin at runtime,
# so API calls go to https://<your-app>.vercel.app/_/backend/api/...
# and the WebSocket connects to wss://<your-app>.vercel.app/_/backend/ws/brain-stream
#
# Users can override this at runtime via the Settings panel (saved to localStorage).
VITE_API_BASE_URL=/_/backend
VITE_BRAIN_STREAM_URL=
